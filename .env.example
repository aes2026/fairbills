# Copy to .env.local and fill in. Never commit real values.

# --- Supabase ---------------------------------------------------------------
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe for the browser; RLS-gated)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (SERVER ONLY — bypasses RLS; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (bill parsing + script generation) --------------------------
ANTHROPIC_API_KEY=

# --- Resend (6-month follow-up email) --------------------------------------
# Without this key the follow-up cron runs in dry-run mode (sends nothing).
RESEND_API_KEY=
# Optional "From" address for follow-up emails (defaults to hello@fairbills.com.au)
FOLLOWUP_FROM=

# --- Follow-up cron + unsubscribe ------------------------------------------
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
# HMAC secret for signing one-click unsubscribe links (any long random string).
FAIRBILLS_SECRET=
# Absolute site URL used in email links, e.g. https://fairbills.com.au
NEXT_PUBLIC_SITE_URL=
